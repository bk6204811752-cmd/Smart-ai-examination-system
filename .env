# ────────────────────────────────────────────────────────────────────────────────
# PCMT AI Exam System - Environment Configuration
# ────────────────────────────────────────────────────────────────────────────────

# ── Environment ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=pcmt_exam

# ── Security - CRITICAL ────────────────────────────────────────────────────────
SECRET_KEY=pcmt-super-secret-key-change-in-production-min-32-characters-required

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────────────────────────
APP_NAME=PCMT Smart AI Exam System
APP_VERSION=1.0.0
DEBUG=true
ALLOW_IN_MEMORY_DB=true

# ── Security Features ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/hour
RATE_LIMIT_GENERAL=100/minute

CSRF_PROTECTION_ENABLED=true
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict

# ── CORS Configuration ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://pcmt-ai-exam-system.vercel.app

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ── Proctoring ─────────────────────────────────────────────────────────────────
PROCTORING_ENABLED=true
FACE_DETECTION_INTERVAL=2
MIN_TRUST_SCORE=60

# ── Data Seeding ───────────────────────────────────────────────────────────────
SEED_DEMO_DATA=false

# ── College Information ────────────────────────────────────────────────────────
COLLEGE_NAME=Pailan College of Management and Technology
COLLEGE_CODE=PCMT
TOTAL_STUDENTS=6000
TOTAL_TEACHERS=250

# ── Admin Email ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@pcmt.edu.in

# ── Email / SMTP Configuration ──────────────────────────────────────────────────
# For Gmail: Use App Password (not regular password)
# Generate App Password: https://myaccount.google.com/apppasswords
# IMPORTANT: Replace with your actual Gmail credentials for email to work
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=PCMT Smart Exam System
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ── OTP Settings ───────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
