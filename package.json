{
  "name": "pcmt-ai-exam-system",
  "version": "1.0.0",
  "private": true,
  "description": "PCMT Smart AI Exam System - Complete Learning Management Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "backend": "cd backend && python app_production.py",
    "backend:dev": "cd backend && python -m uvicorn app_production:app --reload --host 0.0.0.0 --port 8000",
    "backend:prod": "cd backend && gunicorn -w 4 -k uvicorn.workers.UvicornWorker app_production:app --bind 0.0.0.0:8000",
    "backend:test": "cd backend && pytest tests/test_api.py -v --cov=. --cov-report=html",
    "backend:test:quick": "cd backend && pytest tests/test_api.py -v",
    "start:all": "concurrently \"npm run backend:dev\" \"npm run dev\"",
    "start:prod": "concurrently \"npm run backend:prod\" \"npm run preview\"",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:build": "npm run type-check && npm run build && npm run backend:test",
    "deploy:check": "npm run format:check && npm run lint && npm run type-check",
    "health:check": "curl http://localhost:8000/api/health",
    "logs:backend": "Get-Content backend/logs/app.log -Tail 50 -Wait",
    "logs:errors": "Get-Content backend/logs/errors.log -Tail 50 -Wait",
    "clean": "Remove-Item -Recurse -Force dist,node_modules,.vite,backend/__pycache__,backend/.pytest_cache -ErrorAction SilentlyContinue",
    "reinstall": "npm run clean && npm install && cd backend && pip install -r requirements_enhanced.txt"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^0.2.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.8",
    "html2canvas": "^1.4.1",
    "immer": "^11.1.11",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.22.0",
    "react-webcam": "^7.2.0",
    "recharts": "^2.12.2",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.35",
    "source-map-js": "^1.2.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "typescript": "^5.4.2",
    "vite": "^5.2.0"
  }
}
