# ────────────────────────────────────────────────────────────────────────────────
# PCMT AI Exam System - Environment Configuration
# ────────────────────────────────────────────────────────────────────────────────
# Copy this to .env and update with your values

# ── Environment ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Set to 'production' when deploying to Vercel/production servers
# WARNING: Production requires additional security configuration

# ── Database ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=pcmt_exam

# ── Security - CRITICAL ────────────────────────────────────────────────────────
# MUST be 32+ characters, random, and secret. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=pcmt-super-secret-key-change-in-production-min-32-characters-required

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────────────────────────
APP_NAME=PCMT Smart AI Exam System
APP_VERSION=1.0.0
DEBUG=true
# Set DEBUG=false in production

# In-Memory Database (development only)
ALLOW_IN_MEMORY_DB=false
# Set to true only if MongoDB is unavailable and you're in development

# ── Security Features ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/hour
RATE_LIMIT_GENERAL=100/minute

CSRF_PROTECTION_ENABLED=true
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict

# ── CORS Configuration ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://pcmt-ai-exam-system.vercel.app
# Add additional origins separated by commas
# IMPORTANT: Do NOT use wildcards except for development localhost

# ── File Upload ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
# Allowed types: image/jpeg, image/png, application/pdf

# ── Proctoring ─────────────────────────────────────────────────────────────────
PROCTORING_ENABLED=true
FACE_DETECTION_INTERVAL=2
MIN_TRUST_SCORE=60

# ── Data Seeding ───────────────────────────────────────────────────────────────
SEED_DEMO_DATA=false
# Set to true in development to auto-populate demo users and exams

# ── College Information ────────────────────────────────────────────────────────
COLLEGE_NAME=Pailan College of Management and Technology
COLLEGE_CODE=PCMT
TOTAL_STUDENTS=6000
TOTAL_TEACHERS=250

# ─────────────────────────────────────────────────────────────────────────────────
# PRODUCTION CHECKLIST:
# ─────────────────────────────────────────────────────────────────────────────────
# ✓ Set ENVIRONMENT=production
# ✓ Set DEBUG=false
# ✓ Generate new SECRET_KEY (32+ random characters)
# ✓ Use production MongoDB URI
# ✓ Update CORS_ORIGINS to only include production domain
# ✓ Enable HTTPS/TLS on web server (nginx)
# ✓ Set SECURE_COOKIES=true
# ✓ Remove any development origins from CORS_ORIGINS
# ✓ Configure rate limiting appropriately
# ✓ Set up monitoring and logging
# ✓ Test all security features
# ✓ Run security audit
